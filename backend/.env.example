# ============================================================
# ZAMIN X — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
LOG_LEVEL=INFO

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zaminx
DB_USER=zaminx
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# AWS S3 (document storage)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1

# Polygon Blockchain (Phase 3)
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WALLET=0xYourWalletAddress
POLYGON_PRIVATE_KEY=your_private_key_here
LAND_RECORD_CONTRACT=0xContractAddress
OWNERSHIP_CONTRACT=0xContractAddress

# Government APIs (when available via MoU)
BHOOMI_API_URL=
BHOOMI_API_KEY=
DILRMP_API_URL=
DILRMP_API_KEY=

# WhatsApp Business API
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_ACCESS_TOKEN=your_access_token
